{
  "name": "local-code-reviewer-vscode",
  "displayName": "Local AI Code Reviewer",
  "description": "Professional, local-first code review insights using Ollama.",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "localReviewer.reviewFile",
        "title": "Local Reviewer: Review Current File",
        "category": "Local Reviewer"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "localReviewer.reviewFile",
          "group": "navigation",
          "when": "resourceExtname == .cs || resourceExtname == .ts || resourceExtname == .js || resourceExtname == .py"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3",
    "@vscode/test-electron": "^2.3.2"
  },
  "dependencies": {
    "@local-reviewer/core": "*"
  }
}
